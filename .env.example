# Onboarding Application — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Full PostgreSQL connection string
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/onboarding?schema=public"

# ============================================
# n8n INSTANCE
# ============================================
# URL of your n8n instance (with trailing slash)
N8N_URL="https://your-n8n-instance.example.com/"
# API key from n8n → Settings → API → Create API Key
N8N_API_KEY="your-n8n-api-key"

# ============================================
# WORDPRESS / PROFILEGRID
# ============================================
# WordPress site URL (no trailing slash)
WORDPRESS_URL="https://your-wordpress-site.com"
# WordPress username (must have admin or editor role)
WORDPRESS_USERNAME="your-wp-username"
# WordPress Application Password (Settings → Users → Application Passwords)
# Format: "xxxx xxxx xxxx xxxx xxxx xxxx"
WORDPRESS_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
# ProfileGrid REST API base URL (usually wp-json/profilegrid/v1)
PROFILEGRID_API_URL="https://your-wordpress-site.com/wp-json/profilegrid/v1"
# WordPress REST API base URL
WORDPRESS_REST_API_URL="https://your-wordpress-site.com/wp-json/wp/v2"

# ============================================
# SMTP EMAIL
# ============================================
SMTP_HOST="mail.yourdomain.com"
# 465 = SSL, 587 = TLS/STARTTLS
SMTP_PORT="465"
# true for port 465 (SSL), false for port 587 (STARTTLS)
SMTP_SECURE="true"
SMTP_USERNAME="your-smtp-username@yourdomain.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_EMAIL="no-reply@yourdomain.com"
SMTP_FROM_NAME="Your App Onboarding"

# ============================================
# ABSTRACT API (Email Validation & Reputation)
# Sign up at: https://app.abstractapi.com/
# Use the "Email Reputation" API (not "Email Validation")
# Endpoint: https://emailreputation.abstractapi.com/v1
# ============================================
ABSTRACT_API_KEY="your-abstract-api-key"

# ============================================
# APPLICATION
# ============================================
# Public URL where this app is hosted (no trailing slash)
NEXT_PUBLIC_APP_URL="https://onboarding.yourdomain.com"
# Default site metadata for single-site fallback / initial multi-site seed
DEFAULT_SITE_SLUG="your-site-slug"
DEFAULT_SITE_NAME="Your Site Name"
# Random secret for JWT signing — generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-secret-in-production"

# ============================================
# n8n WORKFLOW REFERENCE
# ============================================
# The ID of the "User Onboarding Pipeline" workflow in n8n
N8N_WEBHOOK_ONBOARDING="your-n8n-workflow-id"
# Dedicated template workflows used for future site duplication
N8N_TEMPLATE_SYNC_WORKFLOW_ID="your-template-sync-workflow-id"
N8N_TEMPLATE_REMINDER_WORKFLOW_ID="your-template-reminder-workflow-id"
# Production internal app base URL that onboarding workflows should call
INTERNAL_ONBOARDING_API_BASE="http://YOUR_SERVER_IP:6000"

# ============================================
# ONBOARDING MACHINE AUTHENTICATION
# Legacy global key still used by older non-site-aware routes.
# New onboarding-managed sites now get their own machine key automatically.
# ============================================
N8N_WEBHOOK_AUTH_KEY="your-webhook-auth-key"

# ============================================
# GITEA (for deployment / version control)
# ============================================
GITEA_URL="http://your-gitea-host:3000"
GITEA_USERNAME="your-gitea-username"
# Personal access token from Gitea → Settings → Applications → Generate Token
# Required scopes: repo (read/write)
GITEA_TOKEN="your-gitea-personal-access-token"

# ============================================
# ADDITIONAL APPLICATION SETTINGS
# ============================================
# Support contact shown in reminder/deactivation emails
SUPPORT_EMAIL="support@yourdomain.com"
# Optional login URL included in approval/reminder emails
ACCOUNT_LOGIN_URL="https://your-managed-site.com/login"
# Optional absolute URL for footer image in reminder emails (225x145 recommended)
EMAIL_FOOTER_IMAGE_URL="https://your-app-url.com/images/logo.png"
# Optional user ID to receive reassigned content on forced WP user delete
WORDPRESS_REASSIGN_USER_ID="1"

# ============================================
# DEPLOYMENT & SETUP WIZARD
# ============================================
# Generated by deploy.sh — DO NOT set manually
# Bcrypt hash of the one-time setup PIN printed during deployment
SETUP_PIN_HASH=""
# Set to "true" if credentials were skipped during deploy.sh
# The app will redirect all routes to /setup until this is cleared
SETUP_REQUIRED="false"
# PM2 process name (set by deploy.sh)
PM2_APP_NAME="adob"
# Absolute path where the app is installed (set by deploy.sh)
PROJECT_DIR="/opt/adob"
