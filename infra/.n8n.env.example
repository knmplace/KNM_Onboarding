# n8n local Docker environment — copy to .n8n.env and fill in values
# deploy.sh generates .n8n.env automatically; this file is for manual use only.

N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASS=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
N8N_WEBHOOK_BASE_URL=http://YOUR_SERVER_IP:5678/
TZ=America/New_York
